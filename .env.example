# Copy to .env before using compose.yml or compose.prod.yml.

# Session/data handling
SDSA_SESSION_TTL=1800
SDSA_MAX_UPLOAD_BYTES=314572800
SDSA_SAMPLE_ROWS=10000

# Privacy defaults
SDSA_DEFAULT_K=5
SDSA_DEFAULT_EPSILON=1.0
SDSA_EPSILON_MIN=0.1
SDSA_EPSILON_MAX=10.0
# Lifetime per-column DP budget for a single uploaded session. Repeated noisy
# releases of the same column are refused once cumulative epsilon reaches this,
# which prevents averaging away the noise. Defaults to SDSA_EPSILON_MAX.
SDSA_EPSILON_SESSION_BUDGET=10.0
SDSA_MAX_SUPPRESSION=0.10
SDSA_HARD_MAX_SUPPRESSION=0.50

# Browser origins allowed to call the API directly. Leave empty when serving
# the bundled frontend from the same origin. Do not use "*"; the app rejects it.
SDSA_ALLOWED_CORS_ORIGINS=

# Required only for deterministic cross-session hashes/tokens.
# Generate with: openssl rand -hex 32
# SDSA_DEPLOYMENT_SALT=
